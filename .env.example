# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Optional for now (reserved for future PostgreSQL migration).
DATABASE_URL="postgres://user:password@host:port/dbname"

# APP_URL: URL where the app is hosted locally or in production.
APP_URL="http://localhost:3000"

# Optional superadmin bootstrap. If omitted, the app will show setup screen on first access.
SUPERADMIN_EMAIL="superadmin@seuorg.gov.br"
SUPERADMIN_PASSWORD="TroqueEstaSenhaForte123!"
